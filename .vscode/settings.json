{
    // Use clang-format as the formatter for C/C++ and read rules from .clang-format
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "file",

    // Editor indent settings — pinned so every contributor sees the same
    // indent guides and tab behavior regardless of their global settings.
    // Matches IndentWidth: 4 in .clang-format.
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,

    // Auto-format C/C++ files on save so .clang-format is always applied.
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    }
}
