{
    "version": 4,
    "configurations": [
        {
            "name": "Kuma (Windows MSVC)",

            // Prefer include paths from CMake. Requires the "CMake Tools"
            // extension (ms-vscode.cmake-tools). When this provider is
            // active, the settings below act as fallbacks.
            "configurationProvider": "ms-vscode.cmake-tools",

            // Manual fallbacks in case CMake Tools isn't installed or
            // hasn't configured yet. These keep IntelliSense working with
            // the right language, standard, and first-party include root.
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-x64",

            // Pick up MSVC automatically from a Developer environment.
            "compilerPath": "cl.exe",

            "includePath": [
                "${workspaceFolder}/engine/include/**",
                "${workspaceFolder}/engine/src/**",
                "${workspaceFolder}/build/_deps/sdl3-src/include/**",
                "${workspaceFolder}/build/_deps/googletest-src/googletest/include/**"
            ],

            "defines": [
                "_CRT_SECURE_NO_WARNINGS",
                "WIN32",
                "_WINDOWS"
            ]
        }
    ]
}
